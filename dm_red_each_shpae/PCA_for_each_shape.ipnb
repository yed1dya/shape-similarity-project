{"cells":[{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":333361,"status":"ok","timestamp":1732467218107,"user":{"displayName":"Avi Shtarkberg","userId":"11979278836108927314"},"user_tz":-120},"id":"Fh4RjCO2hDef","outputId":"94f3dc9e-e065-43c2-d1eb-4641975d6e21"},"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","Processing shape1...\n","Loaded 59 images for shape1.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape1_pca_plot.png\n","Processing shape2...\n","Loaded 59 images for shape2.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape2_pca_plot.png\n","Processing shape3...\n","Loaded 59 images for shape3.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape3_pca_plot.png\n","Processing shape4...\n","Loaded 59 images for shape4.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape4_pca_plot.png\n","Processing shape5...\n","Loaded 57 images for shape5.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape5_pca_plot.png\n","Processing shape6...\n","Loaded 59 images for shape6.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape6_pca_plot.png\n","Processing shape7...\n","Loaded 57 images for shape7.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape7_pca_plot.png\n","Processing shape8...\n","Loaded 58 images for shape8.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape8_pca_plot.png\n","Processing shape9...\n","Loaded 57 images for shape9.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape9_pca_plot.png\n","Processing shape10...\n","Loaded 58 images for shape10.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape10_pca_plot.png\n","Processing shape11...\n","Loaded 57 images for shape11.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape11_pca_plot.png\n","Processing shape12...\n","Loaded 57 images for shape12.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape12_pca_plot.png\n","Processing shape13...\n","Loaded 58 images for shape13.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape13_pca_plot.png\n","Processing shape14...\n","Loaded 57 images for shape14.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape14_pca_plot.png\n","Processing shape15...\n","Loaded 57 images for shape15.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape15_pca_plot.png\n","Processing shape16...\n","Loaded 57 images for shape16.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape16_pca_plot.png\n","Processing shape17...\n","Loaded 54 images for shape17.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape17_pca_plot.png\n","Processing shape18...\n","Loaded 55 images for shape18.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape18_pca_plot.png\n","Processing shape19...\n","Loaded 56 images for shape19.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape19_pca_plot.png\n","Processing shape20...\n","Loaded 55 images for shape20.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape20_pca_plot.png\n","Processing shape21...\n","Loaded 54 images for shape21.\n","Saved PCA plot to /content/drive/MyDrive/sample shapes/shapes/pca_plots/shape21_pca_plot.png\n"]}],"source":["from google.colab import drive\n","from sklearn.decomposition import PCA\n","import os\n","import cv2\n","import numpy as np\n","import matplotlib.pyplot as plt\n","\n","# Mount Google Drive\n","drive.mount('/content/drive')\n","\n","# Path to the main folder containing shape folders\n","main_folder_path = '/content/drive/MyDrive/sample shapes/shapes'\n","output_folder_path = os.path.join(main_folder_path, \"pca_plots\")  # Folder to save PCA plots\n","\n","# Create the output folder if it doesn't exist\n","os.makedirs(output_folder_path, exist_ok=True)\n","\n","def load_images_from_folder(folder_path):\n","    \"\"\"\n","    Load all images from a given folder as flattened grayscale arrays.\n","    \"\"\"\n","    data = []\n","    labels = []\n","\n","    for file_name in os.listdir(folder_path):\n","        if file_name.endswith(\".png\"):  # Process only PNG files\n","            file_path = os.path.join(folder_path, file_name)\n","            image = cv2.imread(file_path, cv2.IMREAD_GRAYSCALE)\n","            if image is not None:\n","                resized_image = cv2.resize(image, (32, 32))  # Downscale to 32x32 for faster computation\n","                data.append(resized_image.flatten())  # Flatten the image\n","                labels.append(file_name.split(\".\")[0])  # Use filename without extension as label\n","    return np.array(data), labels\n","\n","def apply_pca(data, n_components=2):\n","    \"\"\"\n","    Apply PCA for dimensionality reduction.\n","    \"\"\"\n","    pca = PCA(n_components=n_components)\n","    reduced_data = pca.fit_transform(data)\n","    return reduced_data\n","\n","def save_pca_plot(reduced_data, labels, output_file_path, shape_name):\n","    \"\"\"\n","    Save a PCA plot with labels to the specified file path.\n","    \"\"\"\n","    plt.figure(figsize=(12, 8))\n","    for i, label in enumerate(labels):\n","        plt.scatter(reduced_data[i, 0], reduced_data[i, 1], alpha=0.7)\n","        plt.text(reduced_data[i, 0], reduced_data[i, 1], label, fontsize=8, alpha=0.9)\n","    plt.title(f\"PCA Clustering for {shape_name}\")\n","    plt.xlabel(\"PCA Dimension 1\")\n","    plt.ylabel(\"PCA Dimension 2\")\n","    plt.savefig(output_file_path)\n","    plt.close()\n","    print(f\"Saved PCA plot to {output_file_path}\")\n","\n","def process_folders_for_pca(main_folder_path, output_folder_path):\n","    \"\"\"\n","    Process each shape folder, apply PCA, and save the plots.\n","    \"\"\"\n","    for shape_folder in os.listdir(main_folder_path):\n","        shape_folder_path = os.path.join(main_folder_path, shape_folder)\n","\n","        # Check if it's a valid shape folder\n","        if os.path.isdir(shape_folder_path) and shape_folder.startswith(\"shape\"):\n","            print(f\"Processing {shape_folder}...\")\n","\n","            data, labels = load_images_from_folder(shape_folder_path)\n","\n","            if data.shape[0] == 0:\n","                print(f\"No images found in {shape_folder}. Skipping.\")\n","                continue\n","\n","            print(f\"Loaded {data.shape[0]} images for {shape_folder}.\")\n","\n","            reduced_data = apply_pca(data)\n","\n","            # Save the PCA plot\n","            output_file_name = f\"{shape_folder}_pca_plot.png\"\n","            output_file_path = os.path.join(output_folder_path, output_file_name)\n","            save_pca_plot(reduced_data, labels, output_file_path, shape_folder)\n","\n","# Main function\n","def main():\n","    # Process each shape folder and generate PCA plots\n","    process_folders_for_pca(main_folder_path, output_folder_path)\n","\n","# Run the main function\n","main()\n"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true,"base_uri":"https://localhost:8080/","height":459},"executionInfo":{"elapsed":4393,"status":"ok","timestamp":1732134180013,"user":{"displayName":"Avi Shtarkberg","userId":"11979278836108927314"},"user_tz":-120},"id":"V5mlT34COY1L","outputId":"a29f6a55-337a-4df9-8f0e-bb2ef8ee9ecd"},"outputs":[{"name":"stdout","output_type":"stream","text":["Collecting umap-learn\n","  Downloading umap_learn-0.5.7-py3-none-any.whl.metadata (21 kB)\n","Requirement already satisfied: numpy>=1.17 in /usr/local/lib/python3.10/dist-packages (from umap-learn) (1.26.4)\n","Requirement already satisfied: scipy>=1.3.1 in /usr/local/lib/python3.10/dist-packages (from umap-learn) (1.13.1)\n","Requirement already satisfied: scikit-learn>=0.22 in /usr/local/lib/python3.10/dist-packages (from umap-learn) (1.5.2)\n","Requirement already satisfied: numba>=0.51.2 in /usr/local/lib/python3.10/dist-packages (from umap-learn) (0.60.0)\n","Collecting pynndescent>=0.5 (from umap-learn)\n","  Downloading pynndescent-0.5.13-py3-none-any.whl.metadata (6.8 kB)\n","Requirement already satisfied: tqdm in /usr/local/lib/python3.10/dist-packages (from umap-learn) (4.66.6)\n","Requirement already satisfied: llvmlite<0.44,>=0.43.0dev0 in /usr/local/lib/python3.10/dist-packages (from numba>=0.51.2->umap-learn) (0.43.0)\n","Requirement already satisfied: joblib>=0.11 in /usr/local/lib/python3.10/dist-packages (from pynndescent>=0.5->umap-learn) (1.4.2)\n","Requirement already satisfied: threadpoolctl>=3.1.0 in /usr/local/lib/python3.10/dist-packages (from scikit-learn>=0.22->umap-learn) (3.5.0)\n","Downloading umap_learn-0.5.7-py3-none-any.whl (88 kB)\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m88.8/88.8 kB\u001b[0m \u001b[31m3.6 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25hDownloading pynndescent-0.5.13-py3-none-any.whl (56 kB)\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m56.9/56.9 kB\u001b[0m \u001b[31m1.9 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25hInstalling collected packages: pynndescent, umap-learn\n","Successfully installed pynndescent-0.5.13 umap-learn-0.5.7\n"]}],"source":["!pip install umap-learn --upgrade"]}],"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNFnedwo1/ZiepZ86bIbqYf"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}